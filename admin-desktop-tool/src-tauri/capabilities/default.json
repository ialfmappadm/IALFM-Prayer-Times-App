{
  "$schema": "https://schema.tauri.app/capability/1.0",
  "identifier": "default",
  "description": "Default capability for main window",
  "windows": ["main"],
  "permissions": [
    "core:default",

    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-message",
    "dialog:allow-ask",
    "dialog:allow-confirm",

    "shell:default",
    "shell:allow-execute",
    "shell:allow-spawn"
  ]
}